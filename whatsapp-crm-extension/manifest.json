{
  "manifest_version": 3,
  "name": "Criare CRM — Atualizar WhatsApp",
  "version": "1.9.2",
  "description": "Atualiza conversas e fotos do WhatsApp Web diretamente no CRM Criare, individualmente ou em lote.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.whatsapp.net/*",
    "https://conradobr-debug.github.io/crm-criare-mogi/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Criare CRM — Atualizar WhatsApp",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://conradobr-debug.github.io/crm-criare-mogi/*"],
      "js": ["content-crm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content-whatsapp.js"],
      "run_at": "document_idle"
    }
  ]
}
