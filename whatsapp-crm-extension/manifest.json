{
  "manifest_version": 3,
  "name": "Criare CRM — Capturar WhatsApp",
  "version": "2.3.2",
  "description": "Captura e salva conversas do WhatsApp Web no CRM Criare; análise e transcrição são fluxos separados.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.whatsapp.net/*",
    "https://conradobr-debug.github.io/crm-criare-mogi/*",
    "http://127.0.0.1:32123/*"
  ],
  "background": {"service_worker": "background.js"},
  "action": {"default_title": "Criare CRM — Capturar WhatsApp", "default_popup": "popup.html"},
  "content_scripts": [
    {
      "matches": ["https://conradobr-debug.github.io/crm-criare-mogi/*"],
      "js": ["content-crm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["phone-identity.js", "capture-core.js", "content-whatsapp.js"],
      "run_at": "document_idle"
    }
  ]
}
